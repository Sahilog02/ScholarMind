# Which LLM provider the agents use: "openrouter" (free, recommended, default),
# "gemini" (free, alternative), "groq" (free, alternative), or "openai"
LLM_PROVIDER=openrouter

# --- OpenRouter (free tier, default) — get a key at https://openrouter.ai/keys ---
# No credit card required. "openrouter/free" is OpenRouter's free-model router:
# it automatically picks an available free, open-source model for each request.
# To pin a specific free model instead, browse https://openrouter.ai/models?max_price=0
# and use its slug (must end in ":free", e.g. "meta-llama/llama-3.3-70b-instruct:free").
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# --- Gemini (free tier, alternative) — get a key at https://aistudio.google.com/apikey ---
# No credit card required. gemini-2.5-flash and gemini-2.5-flash-lite are free
# with rate limits (Gemini Pro models are paid-only). Flash-lite has a higher
# free daily request limit if you hit 429s on flash.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Groq (free tier, alternative) — get a key at https://console.groq.com/keys ---
GROQ_API_KEY=
# Groq deprecates/renames models often — check https://console.groq.com/docs/models
# if this stops working.
GROQ_MODEL=openai/gpt-oss-120b

# --- OpenAI (only used if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Semantic Scholar — optional but strongly recommended, raises your rate limit.
# Request a free key at https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# --- LangSmith observability (free tier) — https://smith.langchain.com ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=scholarmind
