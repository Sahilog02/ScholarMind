# Which LLM provider the agents use: "groq" (free, recommended) or "openai"
LLM_PROVIDER=groq

# --- Groq (free tier) — get a key at https://console.groq.com/keys ---
GROQ_API_KEY=
# Groq deprecates/renames models often — check https://console.groq.com/docs/models
# if this stops working. openai/gpt-oss-120b is current as of mid-2026.
GROQ_MODEL=openai/gpt-oss-120b

# --- OpenAI (only used if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Semantic Scholar — optional but strongly recommended, raises your rate limit.
# Request a free key at https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# --- LangSmith observability (free tier) — https://smith.langchain.com ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=scholarmind
